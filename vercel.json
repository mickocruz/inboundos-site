{
  "headers": [
    {
      "source": "/dashboard/:path*.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com https://www.tiktok.com https://*.tiktok.com https://sf16-website-login.neutral.ttwstatic.com https://*.ttwstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://*.tiktok.com; font-src 'self' blob: https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://cscfbuhwlfhblxprkwnh.supabase.co https://fonts.googleapis.com https://fonts.gstatic.com https://*.tiktok.com https://*.ttwstatic.com; frame-src https://www.tiktok.com https://*.tiktok.com; frame-ancestors 'none';"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/apply.html",
      "destination": "/apply",
      "permanent": true
    }
  ],
